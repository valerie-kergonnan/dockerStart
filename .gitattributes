* text=auto

# Keep Unix line endings for source and Docker-related files
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf
dockerfile text eol=lf
*.sh text eol=lf

# Keep Windows line endings for Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
